    "lint:fix": "biome check --write .",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.13.2"
  }
}
