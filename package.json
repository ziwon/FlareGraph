{
  "name": "flaregraph",
  "private": true,
  "version": "0.1.0",
  "description": "Obsidian-native LLM Wiki / Knowledge Graph / Agentic Retrieval System on Cloudflare",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
