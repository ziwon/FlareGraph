{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flaregraph",
  "main": "src/index.ts",
  "assets": {
    "directory": "console",
    "run_worker_first": ["/api/*", "/mcp"]
  },
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // Template config: the Deploy-to-Cloudflare button provisions these resources
  // and rewrites database_id. Manual deployers: run the `wrangler d1 create` /
  // `r2 bucket create` / `queues create` / `vectorize create` steps in
  // docs/deploy.md and paste your D1 id below. Personal overrides (custom
  // domains, remote-binding tweaks) belong in wrangler.personal.jsonc
  // (gitignored); `just deploy` prefers it when present.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flaregraph",
      "database_id": "<replace-with-your-d1-database-id>",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "VAULT",
      "bucket_name": "flaregraph-vault"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "INDEX_QUEUE",
        "queue": "flaregraph-index"
      }
    ],
    "consumers": [
      {
        "queue": "flaregraph-index",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3,
        "dead_letter_queue": "flaregraph-index-dlq"
      }
    ]
  },
  "vectorize": [
    {
      "binding": "VECTORS",
      "index_name": "flaregraph-chunks"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "EMBEDDING_MODEL": "@cf/baai/bge-m3",
    "LLM_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    "MCP_ENABLE_WRITE": "true",
    "MCP_ENABLE_EXPERIMENTAL": "false",
    "EXCLUDE_FOLDERS": ""
  }
}
